<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/bg_overlay_card"
    android:elevation="10dp"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/overlay_icon"
        android:layout_width="40.dp"
        android:layout_height="40.dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/burner_logo"
        android:contentDescription="App icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/contactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 Burner Contact"
            android:textColor="#FAFAFA"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Temporary contact detected"
            android:textColor="#BDBDBD"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/closeBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_close_btn"
        android:contentDescription="Close overlay"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#FFFFFF" />

</LinearLayout>
